# ConsentLedger Production Environment Variables
# Copy to .env and fill in actual values. NEVER commit .env.

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=consentledger
DB_USERNAME=consentledger
DB_PASSWORD=change-me-strong-password

# ── Application ───────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# JWT signing key — minimum 32 random characters
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-min-32-char-random-string

# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=https://your-domain.com

# OpenAI API key for AI anomaly detection (optional — graceful degradation if empty)
OPENAI_API_KEY=

# ── Docker ────────────────────────────────────────────────────────────────────
# Docker image tag to deploy (default: latest)
IMAGE_TAG=latest

# ── Nginx ─────────────────────────────────────────────────────────────────────
# Server name for nginx virtual host (use _ to match all)
SERVER_NAME=your-domain.com
