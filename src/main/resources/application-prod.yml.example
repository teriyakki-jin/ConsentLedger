# Production configuration template
# Copy this file to application-prod.yml on the production server
# and fill in the actual values. DO NOT commit application-prod.yml.

spring:
  datasource:
    url: jdbc:postgresql://${DB_HOST}:${DB_PORT:5432}/${DB_NAME:consentledger}
    username: ${DB_USERNAME}
    password: ${DB_PASSWORD}
    hikari:
      maximum-pool-size: 50
      minimum-idle: 10
      connection-timeout: 30000
      idle-timeout: 600000
      max-lifetime: 1800000

  jpa:
    hibernate:
      ddl-auto: validate
    show-sql: false

  flyway:
    clean-disabled: true

management:
  endpoints:
    web:
      exposure:
        include: health,info,metrics,prometheus
  endpoint:
    health:
      show-details: when_authorized
  metrics:
    export:
      prometheus:
        enabled: true

app:
  jwt:
    secret: ${JWT_SECRET}                    # min 32-char random string
    expiration-ms: 3600000                   # 1h
    refresh-expiration-ms: 604800000         # 7d

  cors:
    allowed-origins: ${CORS_ALLOWED_ORIGINS} # e.g. https://app.example.com

  ai:
    anomaly:
      max-logs-per-analysis: 500
      max-days: 30

spring.ai:
  openai:
    api-key: ${OPENAI_API_KEY}

logging:
  level:
    root: WARN
    com.consentledger: INFO
    org.flywaydb: INFO
